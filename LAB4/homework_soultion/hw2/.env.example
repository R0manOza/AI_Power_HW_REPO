# HW2 audio pipeline — recommended: OpenAI direct (tts-1 + whisper-1 on api.openai.com).
# Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# If OPENAI_API_KEY is set, it is always used first (OpenRouter is ignored for this script).

# --- Optional fallback: OpenRouter only if you do NOT set OPENAI_API_KEY ---
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_AUDIO_MODEL=openai/gpt-audio-mini

# --- Other course labs (not used by hw2-audio-pipeline.py) ---
# GEMINI_API_KEY=your-gemini-key-here
